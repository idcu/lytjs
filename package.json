{
  "name": "lyt",
  "version": "5.0.0",
  "type": "module",
  "private": true,
  "description": "Lyt.js - 轻写轻跑，所见即代码",
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "scripts": {
    "build": "bash scripts/build-all.sh",
    "test": "npx tsx tests/test-runner.ts",
    "test:coverage": "c8 --reporter=text --reporter=html --reporter=lcov npx tsx tests/test-runner.ts",
    "lint": "eslint packages/*/src/**/*.ts --max-warnings 100",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix --max-warnings 100",
    "benchmark": "npx tsx benchmarks/reactivity.bench.js",
    "benchmark:vapor": "node benchmarks/vapor.bench.js",
    "benchmark:vdom": "node benchmarks/vdom.bench.js",
    "benchmark:all": "npm run benchmark && npm run benchmark:vapor && npm run benchmark:vdom",
    "clean": "rm -rf dist && rm -rf packages/*/dist",
    "clean:temp": "rm -f check-import*.ts unified-test-runner.ts test-scaffold.mjs test-package.mjs rebuild-*.mjs && rm -rf test-projects",
    "publish:dry-run": "bash scripts/publish.sh --dry-run",
    "publish:all": "bash scripts/publish.sh",
    "release": "npm run build && npm run test && npm run publish:all",
    "pack": "node scripts/pack.js",
    "version:check": "node scripts/version.js current",
    "version:set": "node scripts/version.js",
    "version:bump:patch": "node scripts/version.js bump patch",
    "version:bump:minor": "node scripts/version.js bump minor",
    "version:bump:major": "node scripts/version.js bump major",
    "changelog": "node scripts/changelog.js",
    "changelog:add": "node scripts/changelog.js add",
    "changelog:release": "node scripts/changelog.js release",
    "changelog:preview": "node scripts/changelog.js preview",
    "docs:check-encoding": "node check-encoding.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "25.6.0",
    "@typescript-eslint/parser": "8.59.0",
    "archiver": "7.0.1",
    "c8": "11.0.0",
    "esbuild": "^0.28.0",
    "eslint": "10.2.1",
    "get-tsconfig": "4.14.0",
    "jsdom": "29.0.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
