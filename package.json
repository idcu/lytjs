{
  "name": "lytjs",
  "version": "6.7.0",
  "private": true,
  "type": "module",
  "description": "Lyt.js - 下一代轻量级前端框架",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs.git",
    "directory": "/"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "bugs": {
    "url": "https://gitee.com/lytjs/lytjs/issues"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm run build:common && pnpm run build:core && pnpm run build:ecosystem && pnpm run build:web-framework && pnpm run build:tools && pnpm run build:plugins",
    "build:common": "pnpm --filter '@lytjs/common-constants' --filter '@lytjs/common-is' --filter '@lytjs/common-security' --filter '@lytjs/common-string' --filter '@lytjs/common-path' --filter '@lytjs/common-object' --filter '@lytjs/common-error' --filter '@lytjs/common-warn' --filter '@lytjs/common-events' --filter '@lytjs/common-cache' --filter '@lytjs/common-timing' --filter '@lytjs/common-algorithm' --filter '@lytjs/common-vnode' --filter '@lytjs/common-scheduler' --filter '@lytjs/common-dom' --filter '@lytjs/common-query' --filter '@lytjs/common-dom-helpers' --filter '@lytjs/common-a11y' --filter '@lytjs/common-keyboard' --filter '@lytjs/common-storage' --filter '@lytjs/common-validate' --filter '@lytjs/common-http' --filter '@lytjs/common-raf' --filter '@lytjs/common-render-queue' --filter '@lytjs/common-event-normalizer' --filter '@lytjs/common-node-cache' --filter '@lytjs/common-async-scheduler' --filter '@lytjs/common-transition-engine' --filter '@lytjs/common-performance' --filter '@lytjs/common-assertions' --filter '@lytjs/common-memory' run build",
    "build:core": "pnpm --filter '@lytjs/shared-types' --filter '@lytjs/host-contract' --filter '@lytjs/reactivity' --filter '@lytjs/vdom' --filter '@lytjs/component' --filter '@lytjs/renderer' --filter '@lytjs/adapter-web' --filter '@lytjs/dom' --filter '@lytjs/web' --filter '@lytjs/compiler' --filter '@lytjs/core' --filter '@lytjs/core-signal' --filter '@lytjs/core-vnode' --filter '@lytjs/dom-runtime' run build",
    "build:ecosystem": "pnpm --filter '@lytjs/router' --filter '@lytjs/store' --filter '@lytjs/ssr' --filter '@lytjs/ui' --filter '@lytjs/devtools' --filter '@lytjs/compat' --filter '@lytjs/platform-adapter' --filter '@lytjs/router-fs' --filter '@lytjs/api' --filter '@lytjs/bundler' --filter '@lytjs/hmr' --filter '@lytjs/runtime-edge' run build",
    "build:tools": "pnpm --filter '@lytjs/test-utils' --filter '@lytjs/cli' --filter '@lytjs/devtools-extension' run build",
    "build:web-framework": "pnpm --filter '@lytjs/api' --filter '@lytjs/http-server' --filter '@lytjs/metadata' --filter '@lytjs/middleware' --filter '@lytjs/middleware-cors' --filter '@lytjs/middleware-auth' --filter '@lytjs/middleware-rate-limit' --filter '@lytjs/router' --filter '@lytjs/router-fs' run build",
    "build:plugins": "pnpm --filter '@lytjs/plugin-vite' --filter '@lytjs/plugin-theme' --filter '@lytjs/plugin-logger' --filter '@lytjs/plugin-auth' --filter '@lytjs/plugin-storage' --filter '@lytjs/plugin-i18n' --filter '@lytjs/plugin-validation' --filter '@lytjs/plugin-data' --filter '@lytjs/plugin-data-fetch' --filter '@lytjs/plugin-chart' --filter '@lytjs/plugin-animation' --filter '@lytjs/plugin-testing' run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:batch": "tsx scripts/test-batch.ts",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:build": "node e2e/build.cjs",
    "test:reactivity": "pnpm --filter '@lytjs/reactivity' test",
    "test:vdom": "pnpm --filter '@lytjs/vdom' test",
    "test:renderer": "pnpm --filter '@lytjs/renderer' test",
    "test:common": "pnpm -r --filter '@lytjs/common-*' test",
    "test:core": "pnpm --filter '@lytjs/reactivity' --filter '@lytjs/vdom' --filter '@lytjs/renderer' --filter '@lytjs/core' --filter '@lytjs/component' test",
    "bench": "pnpm -C benchmarks run bench",
    "bench:render": "pnpm -C benchmarks run bench:render",
    "bench:update": "pnpm -C benchmarks run bench:update",
    "bench:compare": "pnpm -C benchmarks run compare",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "lint:batch": "tsx scripts/lint-batch.ts",
    "lint:batch:fix": "tsx scripts/lint-batch.ts --fix",
    "lint:reactivity": "eslint packages/reactivity --ext .ts",
    "lint:vdom": "eslint packages/vdom --ext .ts",
    "lint:renderer": "eslint packages/renderer --ext .ts",
    "lint:common": "eslint packages/common --ext .ts",
    "lint:core": "eslint packages/reactivity packages/vdom packages/renderer packages/core packages/component --ext .ts",
    "type-check": "pnpm -r run type-check",
    "type-check:reactivity": "pnpm --filter '@lytjs/reactivity' type-check",
    "type-check:vdom": "pnpm --filter '@lytjs/vdom' type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-deps": "tsx scripts/check-deps.ts",
    "check-zero-deps": "tsx scripts/check-zero-deps.ts",
    "check-circular": "tsx scripts/check-circular.ts",
    "check-circular:src": "tsx scripts/check-circular.ts --src",
    "memlab": "tsx scripts/memlab-check.ts",
    "memlab:gc": "node --expose-gc --loader tsx scripts/memlab-check.ts",
    "sync-versions": "tsx scripts/sync-versions.ts",
    "versions:list": "tsx scripts/update-versions.ts --list",
    "versions:update": "tsx scripts/update-versions.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "publish:prepare": "tsx scripts/prepare-publish.ts",
    "publish:all": "tsx scripts/final-publish.ts",
    "publish:restore": "tsx scripts/restore-workspace.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "size-check": "size-limit",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo && rm -rf node_modules",
    "lighthouse": "tsx scripts/lighthouse.ts",
    "lighthouse:verify": "tsx scripts/lighthouse-runner.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.3.0",
    "madge": "^8.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.4.2",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.20.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css,scss}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "vitest": "^3.0.0",
      "typescript": "^5.8.2"
    }
  }
}
