{
  "name": "lytjs",
  "version": "6.0.0",
  "private": true,
  "type": "module",
  "description": "Lyt.js - 下一代轻量级前端框架",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs.git",
    "directory": "/"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "bugs": {
    "url": "https://gitee.com/lytjs/lytjs/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:build": "node e2e/build.cjs",
    "bench": "vitest bench --config vitest.config.ts",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "type-check": "pnpm -r run type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-deps": "tsx scripts/check-deps.ts",
    "sync-versions": "tsx scripts/sync-versions.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "size-check": "size-limit",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "playwright": "^1.59.1",
    "prettier": "^3.4.2",
    "size-limit": "^11.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css,scss}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {}
  }
}
