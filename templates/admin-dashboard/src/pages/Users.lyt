  background: var(--success-color);
  color: #fff;
}

.btn-success:hover {
  opacity: 0.9;
}

/* 表格 */
.table-card {
  background: var(--card-bg);
  border-radius: 12px;
  border: 1px solid var(--border-color);
  overflow: hidden;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
}

