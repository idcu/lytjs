<template>
  <div class="admin-layout" :class="{ 'sidebar-collapsed': sidebarCollapsed }">
    <!-- 左侧边栏 -->
    <aside class="sidebar">
      <div class="sidebar-logo">
        <span class="logo-icon">L</span>
        <span class="logo-text" if={!sidebarCollapsed}>Admin</span>
      </div>
      <nav class="sidebar-menu">
        <a
          class="menu-item"
          each={item in menuItems}
          :class="{ active: currentRoute === item.path }"
          :href="item.path"
          on:click.prevent="navigateTo(item.path)"
        >
          <span class="menu-icon">{{ item.icon }}</span>
          <span class="menu-label" if={!sidebarCollapsed}>{{ item.label }}</span>
        </a>
      </nav>
      <div class="sidebar-toggle" on:click="toggleSidebar">
        <span class="toggle-icon">{{ sidebarCollapsed ? '>>' : '<<' }}</span>
      </div>
    </aside>

    <!-- 右侧主区域 -->
    <div class="main-area">
      <!-- 顶部栏 -->
      <header class="topbar">
        <div class="topbar-left">
          <nav class="breadcrumb">
            <a class="breadcrumb-item" href="/dashboard">首页</a>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-item current">{{ currentTitle }}</span>
          </nav>
        </div>
        <div class="topbar-right">
          <div class="topbar-action" on:click="toggleFullscreen" title="全屏">
            <span>⛶</span>
          </div>
          <div class="topbar-action" on:click="toggleTheme" title="切换主题">
            <span>{{ theme === 'light' ? '☀' : '☾' }}</span>
          </div>
          <div class="user-dropdown" on:click="toggleUserMenu">
            <div class="user-avatar">
              <span>管</span>
            </div>
            <span class="user-name">Admin</span>
            <span class="dropdown-arrow">▾</span>
            <div class="dropdown-menu" if={showUserMenu}>
              <a class="dropdown-item" href="/profile" on:click.prevent="navigateTo('/profile')">
                <span>👤</span> 个人中心
              </a>
              <div class="dropdown-divider"></div>
              <a class="dropdown-item logout" on:click.prevent="handleLogout">
                <span>🚪</span> 退出登录
              </a>
            </div>
          </div>
        </div>
      </header>

      <!-- 主内容区 -->
      <main class="content-area">
        <router-view />
      </main>
    </div>
  </div>
</template>

<script>
import { inject } from '@lytjs/core'
import { useRouter } from '@lytjs/router'

export default {
  name: 'AdminLayout',

  setup() {
    const router = useRouter()
    const appStore = inject('appStore')
    const userStore = inject('userStore')

    const menuItems = [
      { path: '/dashboard', label: '仪表盘', icon: '📊' },
      { path: '/users', label: '用户管理', icon: '👥' },
      { path: '/roles', label: '角色管理', icon: '🔑' },
      { path: '/settings', label: '系统设置', icon: '⚙' },
    ]

    const state = {
      showUserMenu: false,
    }

    const currentRoute = router.currentRoute.path
    const currentTitle = router.currentRoute.meta?.title || '仪表盘'
    const sidebarCollapsed = appStore.sidebarCollapsed
    const theme = appStore.theme

    const navigateTo = (path: string) => {
      router.push(path)
    }

    const toggleSidebar = () => {
      appStore.toggleSidebar()
    }

    const toggleUserMenu = () => {
      state.showUserMenu = !state.showUserMenu
    }

    const toggleFullscreen = () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen()
      } else {
        document.exitFullscreen()
      }
    }

    const toggleTheme = () => {
      const newTheme = appStore.theme === 'light' ? 'dark' : 'light'
      appStore.setTheme(newTheme)
    }

    const handleLogout = () => {
      userStore.logout()
      router.push('/login')
    }

    return {
      menuItems,
      currentRoute,
      currentTitle,
      sidebarCollapsed,
      theme,
      showUserMenu: state.showUserMenu,
      navigateTo,
      toggleSidebar,
      toggleUserMenu,
      toggleFullscreen,
      toggleTheme,
      handleLogout,
    }
  },
}
</script>

<style scoped>
