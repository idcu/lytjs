/**
 * miniapp-todo 首页样式
 */

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #4A90D9;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 输入区域 */
.input-area {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.todo-input {
  flex: 1;
  height: 72rpx;
  font-size: 30rpx;
  color: #333;
}

.add-btn {
  min-width: 100rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 0 24rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  background-color: #fff;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-item.active {
  background-color: #4A90D9;
  color: #fff;
}

/* 全选按钮 */
.toggle-all {
  text-align: center;
  padding: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #4A90D9;
}

/* Todo 列表 */
.todo-list {
  min-height: 200rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 36rpx;
  color: #ccc;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* Todo 项 */
.todo-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.todo-item.completed {
  opacity: 0.7;
}

.todo-item.editing {
  border: 2rpx solid #4A90D9;
}

/* 复选框 */
.todo-checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 22rpx;
  color: transparent;
  flex-shrink: 0;
}

.todo-checkbox.checked {
  background-color: #4A90D9;
  border-color: #4A90D9;
  color: #fff;
}

/* Todo 文本 */
.todo-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  word-break: break-all;
}

.todo-text.line-through {
  text-decoration: line-through;
  color: #999;
}

/* 操作按钮 */
.todo-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.edit-btn {
  color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.1);
}

.delete-btn {
  color: #ff4d4f;
  background-color: rgba(255, 77, 79, 0.1);
}

/* 编辑模式 */
.edit-input {
  flex: 1;
  height: 56rpx;
  font-size: 30rpx;
  padding: 0 16rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
}

.edit-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
}

.confirm-btn {
  color: #fff;
  background-color: #4A90D9;
}

.cancel-btn {
  color: #666;
  background-color: #f0f0f0;
}

/* 底部 */
.footer {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.clear-btn {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #ff4d4f;
}

/* 信息栏 */
.info-bar {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.info-text {
  font-size: 22rpx;
  color: #ccc;
}
