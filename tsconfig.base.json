{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@lytjs/common-is": ["packages/common/packages/is/src"],
      "@lytjs/common-object": ["packages/common/packages/object/src"],
      "@lytjs/common-string": ["packages/common/packages/string/src"],
      "@lytjs/common-security": ["packages/common/packages/security/src"],
      "@lytjs/common-path": ["packages/common/packages/path/src"],
      "@lytjs/common-events": ["packages/common/packages/events/src"],
      "@lytjs/common-cache": ["packages/common/packages/cache/src"],
      "@lytjs/common-timing": ["packages/common/packages/timing/src"],
      "@lytjs/common-scheduler": ["packages/common/packages/scheduler/src"],
      "@lytjs/common-error": ["packages/common/packages/error/src"],
      "@lytjs/common-algorithm": ["packages/common/packages/algorithm/src"],
      "@lytjs/common-vnode": ["packages/common/packages/vnode/src"],
      "@lytjs/common-env": ["packages/common/packages/env/src"],
      "@lytjs/common": ["packages/common/packages/common/src"],
      "@lytjs/shared-types": ["packages/shared-types/src"],
      "@lytjs/reactivity": ["packages/reactivity/src"],
      "@lytjs/vdom": ["packages/vdom/src"],
      "@lytjs/compiler": ["packages/compiler/src"],
      "@lytjs/renderer": ["packages/renderer/src"],
      "@lytjs/component": ["packages/component/src"],
      "@lytjs/core": ["packages/core/src"],
      "@lytjs/core-vnode": ["packages/core-vnode/src"],
      "@lytjs/core-vnode/*": ["packages/core-vnode/src/*"],
      "@lytjs/core-signal": ["packages/core-signal/src"],
      "@lytjs/core-signal/*": ["packages/core-signal/src/*"]
    },
    "types": ["node"]
  },
  "include": ["env.d.ts", "packages/shared-types/src/global.d.ts"],
  "exclude": ["node_modules", "dist", "**/dist", "**/node_modules"]
}
