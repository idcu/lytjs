{
  "name": "lytjs-npm",
  "description": "Lightweight Zero-Dependency JavaScript Framework - NPM version",
  "version": "6.9.0",
  "keywords": ["lytjs", "benchmark"],
  "type": "module",
  "main": "index.html",
  "js-framework-benchmark": {
    "framework": "LytJS (npm)",
    "frameworkVersion": "6.9.0",
    "useShadowRoot": false,
    "useRowSpan": false,
    "useInnerHTML": false,
    "useDocFragment": true
  },
  "scripts": {
    "dev": "vite",
    "build-prod": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lytjs/adapter-web": "workspace:*",
    "@lytjs/common": "workspace:*",
    "@lytjs/common-dom": "workspace:*",
    "@lytjs/common-error": "workspace:*",
    "@lytjs/common-events": "workspace:*",
    "@lytjs/common-is": "workspace:*",
    "@lytjs/common-scheduler": "workspace:*",
    "@lytjs/common-string": "workspace:*",
    "@lytjs/component": "workspace:*",
    "@lytjs/compiler": "workspace:*",
    "@lytjs/core": "workspace:*",
    "@lytjs/core-signal": "workspace:*",
    "@lytjs/core-vnode": "workspace:*",
    "@lytjs/dom-runtime": "workspace:*",
    "@lytjs/host-contract": "workspace:*",
    "@lytjs/reactivity": "workspace:*",
    "@lytjs/renderer": "workspace:*",
    "@lytjs/shared-types": "workspace:*",
    "@lytjs/vdom": "workspace:*"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "license": "MIT",
  "author": "LytJS Team"
}
