{
  "name": "lytjs-npm-vdom",
  "description": "LytJS - VDOM Mode (npm package)",
  "version": "6.9.0",
  "keywords": ["lytjs", "vdom", "benchmark"],
  "main": "index.html",
  "js-framework-benchmark": {
    "framework": "LytJS (npm, VDOM)",
    "frameworkVersion": "6.9.0",
    "useShadowRoot": false,
    "useRowSpan": false,
    "useInnerHTML": false,
    "useDocFragment": true
  },
  "scripts": {
    "build-prod": "echo 'No build required - production ready'",
    "dev": "python -m http.server 8080"
  },
  "dependencies": {
    "@lytjs/core-vnode": "^6.9.0",
    "@lytjs/reactivity": "^6.9.0",
    "@lytjs/vdom": "^6.9.0",
    "@lytjs/renderer": "^6.9.0",
    "@lytjs/component": "^6.9.0",
    "@lytjs/compiler": "^6.9.0",
    "@lytjs/dom-runtime": "^6.9.0",
    "@lytjs/shared-types": "^6.9.0",
    "@lytjs/common-is": "^6.9.0",
    "@lytjs/common-scheduler": "^6.9.0",
    "@lytjs/common-error": "^6.9.0",
    "@lytjs/common-constants": "^6.9.0",
    "@lytjs/common-assertions": "^6.9.0"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "license": "MIT",
