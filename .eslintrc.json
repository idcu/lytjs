{
  "root": true,
  "env": {
    "es2022": true,
    "node": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": false
    }
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-constant-condition": "warn",
    "no-debugger": "warn",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-extra-semi": "error",
    "no-fallthrough": ["error", { "commentPattern": "break\\s*omitted" }],
    "no-redeclare": "error",
    "no-undef": "off",
    "no-unreachable": "error",
    "no-var": "error",
    "prefer-const": ["warn", { "destructuring": "all" }],
    "eqeqeq": ["warn", "always"],
    "curly": ["warn", "multi-line"]
  },
  "overrides": [
    {
      "files": ["packages/**/*.ts"],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "project": ["./tsconfig.json"]
      },
      "rules": {
        "no-unused-vars": "off"
      }
    },
    {
      "files": ["scripts/**/*.js", "benchmarks/**/*.js", "playground/**/*.js"],
      "env": {
        "browser": true,
        "node": true
      },
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ],
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "es/",
    "lib/",
    "*.d.ts",
    "coverage/",
    "pnpm-lock.yaml",
    "docs-site/",
    "playground/js/lyt-runtime.js",
    "benchmarks/js-framework-benchmark/lyt/dist/"
  ]
}
