{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "lyt": ["packages/core/src"],
      "lyt/*": ["packages/*/src"],
      "@lytjs/reactivity": ["packages/reactivity/src"],
      "@lytjs/reactivity/*": ["packages/reactivity/src/*"],
      "@lytjs/vdom": ["packages/vdom/src"],
      "@lytjs/vdom/*": ["packages/vdom/src/*"],
      "@lytjs/compiler": ["packages/compiler/src"],
      "@lytjs/compiler/*": ["packages/compiler/src/*"],
      "@lytjs/renderer": ["packages/renderer/src"],
      "@lytjs/renderer/*": ["packages/renderer/src/*"],
      "@lytjs/component": ["packages/component/src"],
      "@lytjs/component/*": ["packages/component/src/*"],
      "@lytjs/core": ["packages/core/src"],
      "@lytjs/core/*": ["packages/core/src/*"],
      "@lytjs/router": ["packages/router/src"],
      "@lytjs/router/*": ["packages/router/src/*"],
      "@lytjs/store": ["packages/store/src"],
      "@lytjs/store/*": ["packages/store/src/*"],
      "@lytjs/cli": ["packages/cli/src"],
      "@lytjs/cli/*": ["packages/cli/src/*"],
      "@lytjs/devtools": ["packages/devtools/src"],
      "@lytjs/devtools/*": ["packages/devtools/src/*"],
      "@lytjs/components": ["packages/components/src"],
      "@lytjs/components/*": ["packages/components/src/*"],
      "@lytjs/lytx": ["packages/lytx/src"],
      "@lytjs/lytx/*": ["packages/lytx/src/*"],
      "@lytjs/plugin-i18n": ["packages/plugin-i18n/src"],
      "@lytjs/plugin-auth": ["packages/plugin-auth/src"],
      "@lytjs/plugin-logger": ["packages/plugin-logger/src"],
      "@lytjs/test-utils": ["packages/test-utils/src"],
      "@lytjs/plugins": ["packages/plugins/src"],
      "@lytjs/agg": ["packages/agg/src"]
    }
  },
  "include": ["packages/*/src"],
  "exclude": ["node_modules", "dist", "**/__tests__", "packages/devtools"]
}
