{
  "name": "@lytjs/shared-types",
  "version": "6.0.0",
  "description": "LytJS shared type definitions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@lytjs/vdom": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs.git",
    "directory": "packages/shared-types"
  },
  "keywords": [
    "lytjs",
    "shared-types",
    "types"
  ]
}
