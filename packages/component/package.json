  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "javascript",
    "framework",
    "frontend",
    "vue-like",
    "lightweight",
    "zero-dependency",
    "component",
    "lifecycle",
    "composition-api",
    "keep-alive",
    "transition",
    "组件"
  ],
  "publishConfig": {
    "access": "public"
  }
