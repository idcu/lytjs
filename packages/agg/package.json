{
  "name": "@lytjs/lytjs",
  "version": "4.0.0",
  "description": "Lyt.js - 轻写轻跑，所见即代码。零依赖超轻量前端框架聚合包",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt", "lytjs", "javascript", "framework", "frontend", "vue-like",
    "lightweight", "zero-dependency", "reactive", "vdom"
  ],
  "dependencies": {
    "@lytjs/reactivity": "workspace:*",
    "@lytjs/compiler": "workspace:*",
    "@lytjs/vdom": "workspace:*",
    "@lytjs/renderer": "workspace:*",
    "@lytjs/component": "workspace:*",
    "@lytjs/core": "workspace:*",
    "@lytjs/router": "workspace:*",
    "@lytjs/store": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
