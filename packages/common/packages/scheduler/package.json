{
  "name": "@lytjs/common-scheduler",
  "version": "6.0.0",
  "description": "Task scheduler for LytJS",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "license": "MIT",
  "dependencies": {
    "@lytjs/common-env": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
