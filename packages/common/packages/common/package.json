{
  "name": "@lytjs/common",
  "version": "6.9.2",
  "description": "LytJS common utilities aggregate package",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "license": "MIT",
  "dependencies": {
    "@lytjs/common-env": "workspace:*",
    "@lytjs/common-is": "workspace:*",
    "@lytjs/common-string": "workspace:*",
    "@lytjs/common-path": "workspace:*",
    "@lytjs/common-events": "workspace:*",
    "@lytjs/common-cache": "workspace:*",
    "@lytjs/common-timing": "workspace:*",
    "@lytjs/common-algorithm": "workspace:*",
    "@lytjs/common-vnode": "workspace:*",
    "@lytjs/common-error": "workspace:*",
    "@lytjs/common-object": "workspace:*",
    "@lytjs/common-scheduler": "workspace:*",
    "@lytjs/common-dom": "workspace:*",
    "@lytjs/common-query": "workspace:*",
    "@lytjs/common-dom-helpers": "workspace:*",
    "@lytjs/common-a11y": "workspace:*",
    "@lytjs/common-keyboard": "workspace:*",
    "@lytjs/common-storage": "workspace:*",
    "@lytjs/common-validate": "workspace:*",
    "@lytjs/common-http": "workspace:*",
    "@lytjs/common-raf": "workspace:*",
    "@lytjs/common-warn": "workspace:*",
    "@lytjs/common-render-queue": "workspace:*",
    "@lytjs/common-event-normalizer": "workspace:*",
    "@lytjs/common-node-cache": "workspace:*",
    "@lytjs/common-async-scheduler": "workspace:*",
    "@lytjs/common-transition-engine": "workspace:*",
    "@lytjs/common-performance": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
