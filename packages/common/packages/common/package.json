{
  "name": "@lytjs/common",
  "version": "6.0.0",
  "description": "LytJS common utilities aggregate package",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "license": "MIT",
  "dependencies": {
    "@lytjs/common-env": "^6.0.0",
    "@lytjs/common-is": "^6.0.0",
    "@lytjs/common-string": "^6.0.0",
    "@lytjs/common-path": "^6.0.0",
    "@lytjs/common-events": "^6.0.0",
    "@lytjs/common-cache": "^6.0.0",
    "@lytjs/common-timing": "^6.0.0",
    "@lytjs/common-algorithm": "^6.0.0",
    "@lytjs/common-vnode": "^6.0.0",
    "@lytjs/common-error": "^6.0.0",
    "@lytjs/common-object": "^6.0.0",
    "@lytjs/common-scheduler": "^6.0.0",
    "@lytjs/common-dom": "^6.0.0",
    "@lytjs/common-query": "^6.0.0",
    "@lytjs/common-dom-helpers": "^6.0.0",
    "@lytjs/common-a11y": "^6.0.0",
    "@lytjs/common-keyboard": "^6.0.0",
    "@lytjs/common-storage": "^6.0.0",
    "@lytjs/common-validate": "^6.0.0",
    "@lytjs/common-http": "^6.0.0",
    "@lytjs/common-raf": "^6.0.0",
    "@lytjs/common-warn": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
