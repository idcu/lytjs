{
  "name": "@lytjs/common-dom",
  "version": "6.9.1",
  "description": "Shared DOM utilities for Lyt.js - SVG tags, patchClass, patchStyle, patchAttr, patchProp",
  "keywords": [
    "lytjs",
    "dom",
    "svg",
    "patch"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@lytjs/common-is": "workspace:*",
    "@lytjs/common-string": "workspace:*",
    "@lytjs/common-events": "workspace:*",
    "@lytjs/common-error": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0",
    "jsdom": "^24.0.0"
  }
}
