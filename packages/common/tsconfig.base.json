{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "ES2022.Error", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "composite": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@lytjs/common-env": ["./packages/env/src"],
      "@lytjs/common-is": ["./packages/is/src"],
      "@lytjs/common-string": ["./packages/string/src"],
      "@lytjs/common-security": ["./packages/security/src"],
      "@lytjs/common-path": ["./packages/path/src"],
      "@lytjs/common-events": ["./packages/events/src"],
      "@lytjs/common-cache": ["./packages/cache/src"],
      "@lytjs/common-timing": ["./packages/timing/src"],
      "@lytjs/common-algorithm": ["./packages/algorithm/src"],
      "@lytjs/common-vnode": ["./packages/vnode/src"],
      "@lytjs/common-error": ["./packages/error/src"],
      "@lytjs/common-object": ["./packages/object/src"],
      "@lytjs/common-scheduler": ["./packages/scheduler/src"],
      "@lytjs/common-http": ["./packages/http/src"],
      "@lytjs/common-raf": ["./packages/raf/src"],
      "@lytjs/common": ["./packages/common/src"]
    }
  },
  "exclude": ["node_modules", "dist", "**/tests"]
}
