{
  "name": "@lytjs/store",
  "version": "6.6.0",
  "description": "LytJS Signal-based state management with Option Store and Setup Store patterns",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "echo 'Skipping store build for now'",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lytjs/common-is": "^6.0.0",
    "@lytjs/common-object": "^6.0.0",
    "@lytjs/reactivity": "^6.1.0",
    "@lytjs/component": "^6.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs.git",
    "directory": "packages/ecosystem/packages/store"
  },
  "keywords": [
    "lytjs",
    "store",
    "state",
    "signal",
    "reactive"
  ]
}
