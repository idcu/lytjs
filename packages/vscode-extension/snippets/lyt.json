{
  "Lyt Component": {
    "prefix": "lyt-component",
    "body": [
      "import { defineComponent, ref } from '@lytjs/core'",
      "",
      "export default defineComponent({",
      "  name: '${1:MyComponent}',",
      "  props: {",
      "    ${2:title}: { type: String, default: '' }",
      "  },",
      "  setup(props) {",
      "    const ${3:count} = ref(0)",
      "    return { ${3:count} }",
      "  },",
      "  template: `",
      "    <div class=\"${1:MyComponent}\">",
      "      <h2>{{ ${2:title} }}</h2>",
      "      <p>Count: {{ ${3:count} }}</p>",
      "      <button @click=\"${3:count}++\">Increment</button>",
      "    </div>",
      "  `",
      "})"
    ],
    "description": "Create a Lyt.js component with defineComponent"
  },
  "Lyt Composable": {
    "prefix": "lyt-composable",
    "body": [
      "import { ref, computed, watch } from '@lytjs/reactivity'",
      "",
      "export function use${1:Feature}(${2:options}) {",
      "  const ${3:state} = ref(${4:initialValue})",
      "",
      "  const ${5:computed} = computed(() => {",
      "    return ${3:state}.value * 2",
      "  })",
      "",
      "  watch(${3:state}, (newVal, oldVal) => {",
      "    console.log('${1:Feature} changed:', newVal)",
      "  })",
      "",
      "  return {",
      "    ${3:state},",
      "    ${5:computed}",
      "  }",
      "}"
    ],
    "description": "Create a Lyt.js composable function"
  },
  "Lyt App Setup": {
    "prefix": "lyt-app",
    "body": [
      "import { createApp } from '@lytjs/core'",
      "import App from './App.lyt'",
      "",
      "const app = createApp(App)",
      "",
      "// app.use(plugin)",
      "// app.component('name', component)",
      "",
      "app.mount('#app')"
    ],
    "description": "Create a Lyt.js app entry point"
  },
  "Lyt Ref": {
    "prefix": "lyt-ref",
    "body": ["const ${1:name} = ref(${2:initialValue})"],
    "description": "Create a ref"
  },
  "Lyt Reactive": {
    "prefix": "lyt-reactive",
    "body": ["const ${1:state} = reactive({", "  ${2:key}: ${3:value}", "})"],
    "description": "Create a reactive object"
  },
  "Lyt Computed": {
    "prefix": "lyt-computed",
    "body": ["const ${1:name} = computed(() => {", "  return ${2:expression}", "})"],
    "description": "Create a computed property"
  },
  "Lyt Watch": {
    "prefix": "lyt-watch",
    "body": ["watch(${1:source}, (${2:newVal}, ${3:oldVal}) => {", "  ${4:// handler}", "})"],
    "description": "Create a watcher"
  },
  "Lyt SFC Template": {
    "prefix": "lyt-sfc",
    "body": [
      "<template>",
      "  <div class=\"${1:component}\">",
      "    ${2:content}",
      "  </div>",
      "</template>",
      "",
      "<script>",
      "import { defineComponent, ref } from '@lytjs/core'",
      "",
      "export default defineComponent({",
      "  name: '${1:component}',",
      "  setup() {",
      "    return {}",
      "  }",
      "})",
      "</script>",
      "",
      "<style scoped>",
      "  .${1:component} {",
      "    ${3:styles}",
      "  }",
      "</style>"
    ],
    "description": "Create a Lyt.js SFC (.lyt) template"
  },
  "lyt-composition": {
    "prefix": "lyt-composition",
    "body": [
      "<script setup lang=\"ts\">",
      "import { ref, reactive, computed, watch, onMounted, onUnmounted } from 'lytjs';",
      "",
      "// Reactive state",
      "const ${1:count} = ref(0);",
      "const ${2:state} = reactive({",
      "  ${3:loading}: false,",
      "  ${4:data}: [] as any[],",
      "});",
      "",
      "// Computed",
      "const ${5:doubled} = computed(() => ${1:count}.value * 2);",
      "",
      "// Watch",
      "watch(${1:count}, (newVal, oldVal) => {",
      "  console.log(`${1:count} changed from ${oldVal} to ${newVal}`);",
      "});",
      "",
      "// Lifecycle",
      "onMounted(() => {",
      "  console.log('Component mounted');",
      "});",
      "",
      "onUnmounted(() => {",
      "  console.log('Component unmounted');",
      "});",
      "</script>"
    ],
    "description": "Composition API Setup - Composition API setup 模板"
  },
  "lyt-reactive-advanced": {
    "prefix": "lyt-reactive-advanced",
    "body": [
      "import { ref, reactive, toRefs, isRef, unref } from 'lytjs';",
      "",
      "// ref - 基本类型响应式",
      "const ${1:count} = ref<${2:number}>(0);",
      "const ${3:name} = ref<${4:string}>('');",
      "",
      "// reactive - 对象响应式",
      "const ${5:state} = reactive({",
      "  ${6:items}: [] as ${7:string}[],",
      "  ${8:loading}: false,",
      "  ${9:error}: null as string | null,",
      "});",
      "",
      "// toRefs - 解构响应式对象",
      "const { ${6:items}, ${8:loading}, ${9:error} } = toRefs(${5:state});",
      "",
      "// 修改值",
      "${1:count}.value++;",
      "${3:name}.value = 'hello';",
      "${5:state}.${6:items}.push('new item');"
    ],
    "description": "Reactive / Ref - reactive/ref 使用模板"
  },
  "lyt-computed-advanced": {
    "prefix": "lyt-computed-advanced",
    "body": [
      "import { computed } from 'lytjs';",
      "",
      "// 只读计算属性",
      "const ${1:fullName} = computed(() => {",
      "  return `${${2:firstName}.value} ${${3:lastName}.value}`;",
      "});",
      "",
      "// 可写计算属性",
      "const ${4:fullName} = computed({",
      "  get() {",
      "    return `${${2:firstName}.value} ${${3:lastName}.value}`;",
      "  },",
      "  set(value: string) {",
      "    const [first, last] = value.split(' ');",
      "    ${2:firstName}.value = first || '';",
      "    ${3:lastName}.value = last || '';",
      "  },",
      "});"
    ],
    "description": "Computed - computed 使用模板"
  },
  "lyt-watch-advanced": {
    "prefix": "lyt-watch-advanced",
    "body": [
      "import { watch, watchEffect } from 'lytjs';",
      "",
      "// 监听单个 ref",
      "watch(${1:sourceRef}, (newVal, oldVal) => {",
      "  console.log('changed:', oldVal, '->', newVal);",
      "});",
      "",
      "// 监听多个源",
      "watch([${2:source1}, ${3:source2}], ([new1, new2], [old1, old2]) => {",
      "  console.log('multiple sources changed');",
      "});",
      "",
      "// 带配置选项",
      "watch(${4:source}, (newVal, oldVal) => {",
      "  // handler",
      "}, {",
      "  immediate: true,",
      "  deep: true,",
      "  flush: 'pre', // 'pre' | 'post' | 'sync'",
      "});",
      "",
      "// watchEffect - 自动追踪依赖",
      "watchEffect(() => {",
      "  console.log(${5:source}.value);",
      "});",
      "",
      "// 停止监听",
      "const stop = watch(${6:source}, () => {});",
      "// stop();"
    ],
    "description": "Watch - watch 使用模板"
  },
  "lyt-lifecycle": {
    "prefix": "lyt-lifecycle",
    "body": [
      "import {",
      "  onBeforeMount,",
      "  onMounted,",
      "  onBeforeUpdate,",
      "  onUpdated,",
      "  onBeforeUnmount,",
      "  onUnmounted,",
      "  onErrorCaptured,",
      "  onActivated,",
      "  onDeactivated,",
      "} from 'lytjs';",
      "",
      "onBeforeMount(() => {",
      "  console.log('Component is about to mount');",
      "});",
      "",
      "onMounted(() => {",
      "  console.log('Component is mounted');",
      "});",
      "",
      "onBeforeUpdate(() => {",
      "  console.log('Component is about to update');",
      "});",
      "",
      "onUpdated(() => {",
      "  console.log('Component is updated');",
      "});",
      "",
      "onBeforeUnmount(() => {",
      "  console.log('Component is about to unmount');",
      "});",
      "",
      "onUnmounted(() => {",
      "  console.log('Component is unmounted');",
      "});",
      "",
      "onErrorCaptured((err, instance, info) => {",
      "  console.error('Error captured:', err, info);",
      "  return false;",
      "});",
      "",
      "onActivated(() => {",
      "  console.log('KeepAlive component activated');",
      "});",
      "",
      "onDeactivated(() => {",
      "  console.log('KeepAlive component deactivated');",
      "});"
    ],
    "description": "Lifecycle Hooks - 生命周期钩子模板"
  },
  "lyt-if": {
    "prefix": "lyt-if",
    "body": [
      "<!-- v-if / v-else-if / v-else -->",
      "<div v-if=\"${1:condition}\">",
      "  ${2:Content when condition is true}",
      "</div>",
      "<div v-else-if=\"${3:otherCondition}\">",
      "  ${4:Content when otherCondition is true}",
      "</div>",
      "<div v-else>",
      "  ${5:Content when all conditions are false}",
      "</div>",
      "",
      "<!-- v-show (CSS display toggle) -->",
      "<div v-show=\"${6:isVisible}\">",
      "  ${7:Toggle visible content}",
      "</div>"
    ],
    "description": "Conditional Rendering - 条件渲染"
  },
  "lyt-each": {
    "prefix": "lyt-each",
    "body": [
      "<!-- 遍历数组 -->",
      "<ul>",
      "  <li v-each=\"(item, index) in ${1:items}\" :key=\"item.${2:id}\">",
      "    {{ index }}: {{ item.${3:name} }}",
      "  </li>",
      "</ul>",
      "",
      "<!-- 遍历对象 -->",
      "<div v-each=\"(value, key, index) in ${4:object}\" :key=\"key\">",
      "  {{ key }}: {{ value }}",
      "</div>",
      "",
      "<!-- 遍历数字范围 -->",
      "<span v-each=\"n in ${5:10}\" :key=\"n\">",
      "  {{ n }}",
      "</span>"
    ],
    "description": "List Rendering - 列表渲染"
  },
  "lyt-model": {
    "prefix": "lyt-model",
    "body": [
      "<!-- 文本输入 -->",
      "<input v-model=\"${1:message}\" type=\"text\" placeholder=\"edit me\" />",
      "",
      "<!-- 多行文本 -->",
      "<textarea v-model=\"${2:message}\"></textarea>",
      "",
      "<!-- 复选框 -->",
      "<input type=\"checkbox\" v-model=\"${3:checked}\" />",
      "",
      "<!-- 单选按钮 -->",
      "<input type=\"radio\" value=\"${4:one}\" v-model=\"${5:picked}\" />",
      "<input type=\"radio\" value=\"${6:two}\" v-model=\"${5:picked}\" />",
      "",
      "<!-- 选择框 -->",
      "<select v-model=\"${7:selected}\">",
      "  <option disabled value=\"\">Please select one</option>",
      "  <option>${8:A}</option>",
      "  <option>${9:B}</option>",
      "</select>",
      "",
      "<!-- 修饰符 -->",
      "<input v-model.trim=\"${10:msg}\" />",
      "<input v-model.number=\"${11:age}\" type=\"number\" />",
      "<input v-model.lazy=\"${12:msg}\" />"
    ],
    "description": "Two-way Binding - 双向绑定"
  },
  "lyt-event": {
    "prefix": "lyt-event",
    "body": [
      "<!-- 内联事件处理器 -->",
      "<button @click=\"${1:count}++\">Increment</button>",
      "",
      "<!-- 方法事件处理器 -->",
      "<button @click=\"${2:handleClick}\">Click me</button>",
      "",
      "<!-- 内联方法调用 -->",
      "<button @click=\"${3:handleClick}($event, ${4:arg})\">Click with args</button>",
      "",
      "<!-- 事件修饰符 -->",
      "<form @submit.prevent=\"${5:onSubmit}\">",
      "  <button type=\"submit\">Submit</button>",
      "</form>",
      "",
      "<!-- 按键修饰符 -->",
      "<input @keyup.enter=\"${6:onEnter}\" />",
      "<input @keyup.esc=\"${7:onEscape}\" />",
      "",
      "<!-- 自定义事件 -->",
      "<${8:child-component}",
      "  @${9:custom-event}=\"${10:handleCustomEvent}\"",
      "  @update:modelValue=\"${11:newVal} = $event\"",
      "/>"
    ],
    "description": "Event Handling - 事件处理"
  },
  "lyt-slot": {
    "prefix": "lyt-slot",
    "body": [
      "<!-- 默认插槽 -->",
      "<slot>",
      "  ${1:Default content}",
      "</slot>",
      "",
      "<!-- 具名插槽 -->",
      "<slot name=\"${2:header}\">",
      "  ${3:Default header content}",
      "</slot>",
      "<slot name=\"${4:footer}\">",
      "  ${5:Default footer content}",
      "</slot>",
      "",
      "<!-- 作用域插槽 -->",
      "<slot :${6:item}=\"${7:item}\" :${8:index}=\"${9:index}\">",
      "  {{ ${7:item}.${10:name} }}",
      "</slot>",
      "",
      "<!-- 使用具名插槽 -->",
      "<${11:child-component}>",
      "  <template #${2:header}>",
      "    <h1>${12:Header content}</h1>",
      "  </template>",
      "  <template #${4:footer}>",
      "    <p>${13:Footer content}</p>",
      "  </template>",
      "  ${14:Default slot content}",
      "</${11:child-component}>",
      "",
      "<!-- 使用作用域插槽 -->",
      "<${15:list-component}>",
      "  <template #default=\"{ ${6:item}, ${8:index} }\">",
      "    <div>{{ ${8:index} }}: {{ ${6:item}.${10:name} }}</div>",
      "  </template>",
      "</${15:list-component}>"
    ],
    "description": "Slot - 插槽"
  },
  "lyt-props": {
    "prefix": "lyt-props",
    "body": [
      "// TypeScript 方式定义 Props",
      "const props = defineProps<{",
      "  /** 标题文本 */",
      "  title: string;",
      "  /** 数量 */",
      "  count?: number;",
      "  /** 是否禁用 */",
      "  disabled?: boolean;",
      "  /** 列表数据 */",
      "  items?: string[];",
      "  /** 回调函数 */",
      "  onChange?: (value: string) => void;",
      "}>();",
      "",
      "// 带默认值的 Props",
      "const props = withDefaults(defineProps<{",
      "  title: string;",
      "  count?: number;",
      "  disabled?: boolean;",
      "  theme?: 'light' | 'dark';",
      "}>(), {",
      "  count: 0,",
      "  disabled: false,",
      "  theme: 'light',",
      "});",
      "",
      "// 使用 props",
      "console.log(props.title);",
      "console.log(props.count);"
    ],
    "description": "Props Definition - Props 定义"
  },
  "lyt-emits": {
    "prefix": "lyt-emits",
    "body": [
      "// TypeScript 方式定义 Emits",
      "const emit = defineEmits<{",
      "  (e: 'change', value: string): void;",
      "  (e: 'update', id: number, value: string): void;",
      "  (e: 'delete', id: number): void;",
      "  (e: 'submit', payload: { name: string; age: number }): void;",
      "}>();",
      "",
      "// 触发事件",
      "emit('change', '${1:new value}');",
      "emit('update', ${2:1}, '${3:updated}');",
      "emit('delete', ${4:id});",
      "emit('submit', { name: '${5:foo}', age: ${6:20} });",
      "",
      "// 在模板中使用",
      "// <${7:child-component} @change=\"handleChange\" @submit=\"handleSubmit\" />"
    ],
    "description": "Emits Definition - Emits 定义"
  },
  "lyt-store": {
    "prefix": "lyt-store",
    "body": [
      "import { defineStore } from 'lytjs/store';",
      "",
      "// 定义 Store",
      "export const use${1:Counter}Store = defineStore('${2:counter}', () => {",
      "  // State",
      "  const ${3:count} = ref(0);",
      "  const ${4:name} = ref('${5:Ly t.js}');",
      "",
      "  // Getters",
      "  const ${6:doubledCount} = computed(() => ${3:count}.value * 2);",
      "",
      "  // Actions",
      "  function increment() {",
      "    ${3:count}.value++;",
      "  }",
      "",
      "  function decrement() {",
      "    ${3:count}.value--;",
      "  }",
      "",
      "  function reset() {",
      "    ${3:count}.value = 0;",
      "    ${4:name}.value = '${5:Ly t.js}';",
      "  }",
      "",
      "  async function fetch${7:Data}() {",
      "    const response = await fetch('/api/${8:data}');",
      "    return response.json();",
      "  }",
      "",
      "  return {",
      "    ${3:count},",
      "    ${4:name},",
      "    ${6:doubledCount},",
      "    increment,",
      "    decrement,",
      "    reset,",
      "    fetch${7:Data},",
      "  };",
      "});",
      "",
      "// 在组件中使用",
      "// const store = use${1:Counter}Store();",
      "// store.increment();",
      "// console.log(store.${6:doubledCount});"
    ],
    "description": "Store - Store 使用模板"
  },
  "lyt-router": {
    "prefix": "lyt-router",
    "body": [
      "import { useRouter, useRoute, onBeforeRouteLeave, onBeforeRouteUpdate } from 'lytjs/router';",
      "",
      "const router = useRouter();",
      "const route = useRoute();",
      "",
      "// 编程式导航",
      "router.push('${1:/path}');",
      "router.push({ name: '${2:routeName}', params: { id: ${3:1} } });",
      "router.push({ path: '${1:/path}', query: { foo: '${4:bar}' } });",
      "router.replace('${1:/path}');",
      "router.go(-1);",
      "router.back();",
      "router.forward();",
      "",
      "// 获取路由参数",
      "const ${5:id} = route.params.id;",
      "const ${6:query} = route.query.search;",
      "",
      "// 路由守卫",
      "onBeforeRouteLeave((to, from, next) => {",
      "  const answer = window.confirm('Do you really want to leave?');",
      "  if (answer) {",
      "    next();",
      "  } else {",
      "    next(false);",
      "  }",
      "});",
      "",
      "onBeforeRouteUpdate((to, from, next) => {",
      "  next();",
      "});",
      "",
      "// 模板中使用",
      "// <router-link to=\"${1:/path}\">${7:Link}</router-link>",
      "// <router-view />"
    ],
    "description": "Router - Router 使用模板"
  }
}
