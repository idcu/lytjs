{
  "name": "@lytjs/components",
  "version": "4.0.0",
  "description": "Lyt.js 官方组件库 - 提供按钮、表单、表格、弹窗、标签页等常用 UI 组件",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt", "lytjs", "javascript", "framework", "frontend", "vue-like",
    "lightweight", "zero-dependency", "components", "ui", "button", "form"
  ],
  "dependencies": {
    "@lytjs/component": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
