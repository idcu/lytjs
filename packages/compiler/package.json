{
  "name": "@lytjs/compiler",
  "version": "4.0.0",
  "description": "Lyt.js 模板编译器 - 将模板字符串编译为渲染函数，支持指令解析和优化",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./sfc": {
      "types": "./dist/types/sfc-entry.d.ts",
      "import": "./dist/sfc-entry.mjs",
      "require": "./dist/sfc-entry.cjs",
      "default": "./dist/sfc-entry.mjs"
    },
    "./wasm": {
      "types": "./dist/types/wasm-entry.d.ts",
      "import": "./dist/wasm-entry.mjs",
      "require": "./dist/wasm-entry.cjs",
      "default": "./dist/wasm-entry.mjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "javascript",
    "framework",
    "frontend",
    "vue-like",
    "lightweight",
    "zero-dependency",
    "compiler",
    "template",
    "sfc",
    "编译器",
    "模板"
  ],
  "publishConfig": {
    "access": "public"
  }
}
