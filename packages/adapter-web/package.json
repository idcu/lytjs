{
  "name": "@lytjs/adapter-web",
  "version": "6.0.0",
  "description": "LytJS Web platform adapter - RendererHost implementation for browser DOM",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lytjs/host-contract": "^6.0.0",
    "@lytjs/common-dom": "^6.0.0",
    "@lytjs/common-events": "^6.0.0",
    "@lytjs/common-is": "^6.0.0",
    "@lytjs/common-string": "^6.0.0",
    "@lytjs/common-error": "^6.0.0",
    "@lytjs/shared-types": "^6.0.0",
    "@lytjs/vdom": "^6.0.0",
    "@lytjs/reactivity": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.8.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs.git",
    "directory": "packages/adapter-web"
  },
  "keywords": [
    "lytjs",
    "adapter-web",
    "dom",
    "renderer"
  ]
}
