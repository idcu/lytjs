{
  "name": "@lytjs/adapter-web",
  "version": "6.9.1",
  "description": "LytJS Web 平台适配器 - 浏览器 DOM 的 RendererHost 实现",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lytjs/host-contract": "workspace:*",
    "@lytjs/common-dom": "workspace:*",
    "@lytjs/common-events": "workspace:*",
    "@lytjs/common-is": "workspace:*",
    "@lytjs/common-string": "workspace:*",
    "@lytjs/common-error": "workspace:*",
    "@lytjs/shared-types": "workspace:*",
    "@lytjs/vdom": "workspace:*",
    "@lytjs/reactivity": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs.git",
    "directory": "packages/adapter-web"
  },
  "keywords": [
    "lytjs",
    "adapter-web",
    "dom",
    "renderer"
  ]
}
