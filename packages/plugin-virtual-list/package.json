{
  "name": "@lytjs/plugin-virtual-list",
  "version": "5.0.1",
  "description": "Lyt.js 虚拟列表插件 - 提供高性能虚拟滚动列表组件，支持动态高度和大数据量渲染",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "virtual-list",
    "虚拟列表",
    "virtual-scroll",
    "滚动",
    "性能",
    "performance",
    "大数据",
    "zero-dependency"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
