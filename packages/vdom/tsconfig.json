{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": "./src",
    "allowImportingTsExtensions": true,
    "noEmit": false,
    "noEmitOnError": false,
    "paths": {
      "@lytjs/reactivity": ["../reactivity/dist/types"],
      "@lytjs/reactivity/*": ["../reactivity/dist/types/*"],
      "@lytjs/common": ["../common/dist/types"],
      "@lytjs/common/*": ["../common/dist/types/*"],
      "@lytjs/vdom": ["./src"],
      "@lytjs/vdom/*": ["./src/*"],
      "@lytjs/compiler": ["../compiler/dist/types"],
      "@lytjs/compiler/*": ["../compiler/dist/types/*"],
      "@lytjs/renderer": ["../renderer/dist/types"],
      "@lytjs/renderer/*": ["../renderer/dist/types/*"],
      "@lytjs/component": ["../component/dist/types"],
      "@lytjs/component/*": ["../component/dist/types/*"],
      "@lytjs/core": ["../core/dist/types"],
      "@lytjs/core/*": ["../core/dist/types/*"],
      "@lytjs/router": ["../router/dist/types"],
      "@lytjs/router/*": ["../router/dist/types/*"],
      "@lytjs/store": ["../store/dist/types"],
      "@lytjs/store/*": ["../store/dist/types/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__"]
}
