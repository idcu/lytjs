{
  "name": "@lytjs/vdom",
  "version": "6.4.0",
  "description": "LytJS virtual DOM - vnode creation, diffing algorithm, and patch flags",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./transition": {
      "types": "./dist/transition.d.ts",
      "import": "./dist/transition.mjs",
      "require": "./dist/transition.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lytjs/shared-types": "^6.4.0",
    "@lytjs/common-is": "^6.4.0",
    "@lytjs/common-vnode": "^6.4.0",
    "@lytjs/common-algorithm": "^6.4.0",
    "@lytjs/common-string": "^6.4.0",
    "@lytjs/common-events": "^6.4.0",
    "@lytjs/common-dom": "^6.4.0",
    "@lytjs/common-transition-engine": "^6.4.0",
    "@lytjs/common-assertions": "^6.4.0",
    "@lytjs/common-error": "^6.4.0",
    "@lytjs/common-object": "^6.4.0",
    "@lytjs/common-constants": "^6.4.0",
    "@lytjs/host-contract": "^6.4.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0"
  },
  "license": "MIT"
}
