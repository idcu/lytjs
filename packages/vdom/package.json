{
  "name": "@lytjs/vdom",
  "version": "6.9.0",
  "description": "LytJS virtual DOM - vnode creation, diffing algorithm, and patch flags",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./transition": {
      "types": "./dist/transition.d.ts",
      "import": "./dist/transition.mjs",
      "require": "./dist/transition.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lytjs/shared-types": "workspace:*",
    "@lytjs/common-is": "workspace:*",
    "@lytjs/common-vnode": "workspace:*",
    "@lytjs/common-algorithm": "workspace:*",
    "@lytjs/common-string": "workspace:*",
    "@lytjs/common-events": "workspace:*",
    "@lytjs/common-dom": "workspace:*",
    "@lytjs/common-transition-engine": "workspace:*",
    "@lytjs/common-assertions": "workspace:*",
    "@lytjs/common-error": "workspace:*",
    "@lytjs/common-object": "workspace:*",
    "@lytjs/common-constants": "workspace:*",
    "@lytjs/host-contract": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.0",
    "jsdom": "^29.1.1"
  },
  "license": "MIT"
}
