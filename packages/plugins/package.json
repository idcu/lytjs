{
  "name": "@lytjs/plugins",
  "version": "4.0.5",
  "description": "Lyt.js 官方插件聚合包 - 统一导出国际化、认证、日志、存储和主题等官方插件",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "javascript",
    "framework",
    "frontend",
    "vue-like",
    "lightweight",
    "zero-dependency",
    "plugins",
    "i18n",
    "auth",
    "logger",
    "storage",
    "theme",
    "dark-mode"
  ],
  "dependencies": {
    "@lytjs/plugin-i18n": "workspace:*",
    "@lytjs/plugin-auth": "workspace:*",
    "@lytjs/plugin-logger": "workspace:*",
    "@lytjs/plugin-storage": "workspace:*",
    "@lytjs/plugin-theme": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
