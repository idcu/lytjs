{
  "name": "@lytjs/plugin-websocket",
  "version": "5.2.0",
  "description": "WebSocket plugin for Lyt.js - auto-reconnect, heartbeat, message queue, JSON serialization",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "websocket",
    "ws",
    "real-time",
    "reconnect",
    "heartbeat",
    "socket"
  ],
  "publishConfig": {
    "access": "public"
  }
}
