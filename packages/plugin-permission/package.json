{
  "name": "@lytjs/plugin-permission",
  "version": "5.2.0",
  "description": "Permission control plugin for Lyt.js - role-based access control with directives and API refresh",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "permission",
    "rbac",
    "role",
    "access-control",
    "authorization",
    "directive"
  ],
  "publishConfig": {
    "access": "public"
  }
}
