{
  "name": "@lytjs/plugin-sdk",
  "version": "5.0.1",
  "description": "Lyt.js 插件开发 SDK - 提供插件规范、开发工具和验证器",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "plugin",
    "sdk",
    "plugin-sdk",
    "marketplace",
    "extension",
    "framework"
  ],
  "dependencies": {
    "@lytjs/core": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
