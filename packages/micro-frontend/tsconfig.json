{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": "./src",
    "allowImportingTsExtensions": true,
    "noEmit": false,
    "noEmitOnError": false,
    "paths": {
      "@lytjs/common": [
        "../common/dist/types"
      ],
      "@lytjs/common/*": [
        "../common/dist/types/*"
      ],
      "@lytjs/core": [
        "../core/dist/types"
      ],
      "@lytjs/core/*": [
        "../core/dist/types/*"
      ]
    },
    "types": [
      "node"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__"
  ]
}
