{
  "name": "@lytjs/renderer",
  "version": "3.2.1",
  "description": "Lyt.js 渲染器 - 多平台渲染抽象层（DOM/SSR/Native/MiniApp）",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt", "lytjs", "javascript", "framework", "frontend", "vue-like",
    "lightweight", "zero-dependency", "renderer", "dom", "ssr"
  ],
  "dependencies": {
    "@lytjs/reactivity": "workspace:*",
    "@lytjs/vdom": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
