{
  "name": "@lytjs/renderer",
  "version": "6.4.0",
  "description": "LytJS renderer - DOM, SSR, and Vapor rendering backends",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.mjs",
      "require": "./dist/dom.cjs"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.mjs",
      "require": "./dist/ssr.cjs"
    },
    "./vapor": {
      "types": "./dist/vapor/vapor-app.d.ts",
      "import": "./dist/vapor/vapor-app.mjs",
      "require": "./dist/vapor/vapor-app.cjs"
    },
    "./vapor/vapor-app": {
      "types": "./dist/vapor/vapor-app.d.ts",
      "import": "./dist/vapor/vapor-app.mjs",
      "require": "./dist/vapor/vapor-app.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lytjs/reactivity": "^6.4.0",
    "@lytjs/vdom": "^6.4.0",
    "@lytjs/common-is": "^6.4.0",
    "@lytjs/common-string": "^6.4.0",
    "@lytjs/common-events": "^6.4.0",
    "@lytjs/common-dom": "^6.4.0",
    "@lytjs/common-error": "^6.4.0",
    "@lytjs/dom-runtime": "^6.4.0",
    "@lytjs/compiler": "^6.4.0",
    "@lytjs/host-contract": "^6.4.0",
    "@lytjs/adapter-web": "^6.4.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0"
  },
  "license": "MIT"
}
