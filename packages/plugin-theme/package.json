{
  "name": "@lytjs/plugin-theme",
  "version": "4.1.0",
  "description": "Lyt.js 主题切换插件 - 支持亮色/暗色主题和自定义主题",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "license": "MIT",
  "author": "lytjs",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/lytjs/lytjs"
  },
  "homepage": "https://gitee.com/lytjs/lytjs",
  "keywords": [
    "lyt",
    "lytjs",
    "javascript",
    "framework",
    "frontend",
    "vue-like",
    "lightweight",
    "zero-dependency",
    "theme",
    "dark-mode",
    "color-scheme"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
